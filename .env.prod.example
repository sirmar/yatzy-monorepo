# GitHub Container Registry repo slug (e.g. yourorg/yatzy-monorepo)
GHCR_REPO=

# Image tag to deploy (e.g. v1.2.3 or latest)
TAG=latest

# Backend database
YATZY_DB_ROOT_PASSWORD=
YATZY_DB_NAME=yatzy
BACKEND_DATABASE_URL=mysql://root:CHANGEME@yatzy-db:3306/yatzy

# Auth database
AUTH_DB_ROOT_PASSWORD=
AUTH_DB_NAME=yatzy_auth
AUTH_DATABASE_URL=mysql://root:CHANGEME@auth-db:3306/yatzy_auth

# Shared secret for JWT signing — must match between backend and auth
JWT_SECRET=
