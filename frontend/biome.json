{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.pnpm-store",
      "!**/dist",
      "!**/coverage",
      "!**/.vite",
      "!**/src/api/schema.ts",
      "!**/src/auth/schema.ts",
      "!**/src/components/ui",
      "!**/src/hooks/use-toast.ts",
      "!**/test-results",
      "!**/playwright-report"
    ]
  }
}
